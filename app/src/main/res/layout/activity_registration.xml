<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bus_blue">

    <!-- header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back_arrow"
            android:contentDescription="Back"
            app:tint="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="BACK"
            android:textColor="@color/white"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- scrollable content -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registration"
                android:textColor="@color/bus_yellow"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <!-- bottom text sa title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Create your Cebu SouthBus account"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:gravity="center"/>

            <!-- regis card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- journey header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Your journey starts here, Take the first step"
                        android:textColor="@color/text_dark"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="2dp"/>

                    <!-- req field indicator -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/dot_yellow"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Required field"
                            android:textColor="#666666"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- first name -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="First name"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"/>

                    <EditText
                        android:id="@+id/etFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/feedback_input_background"
                        android:padding="12dp"
                        android:hint=""
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:inputType="textPersonName|textCapWords"/>

                    <!-- middle name -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Middle name"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"/>

                    <EditText
                        android:id="@+id/etMiddleName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/feedback_input_background"
                        android:padding="12dp"
                        android:hint=""
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:inputType="textPersonName|textCapWords"/>

                    <!-- last name -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Last name"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"/>

                    <EditText
                        android:id="@+id/etLastName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/feedback_input_background"
                        android:padding="12dp"
                        android:hint=""
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:inputType="textPersonName|textCapWords"/>

                    <!-- email -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Email"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/feedback_input_background"
                        android:padding="12dp"
                        android:hint=""
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"/>

                    <!-- pass -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Password"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"/>

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/feedback_input_background"
                        android:padding="12dp"
                        android:hint=""
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:inputType="textPassword"/>

                    <!-- confirm password -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Confirm Password"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"/>

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/feedback_input_background"
                        android:padding="12dp"
                        android:hint=""
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:inputType="textPassword"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- create acc button (Moved inside ScrollView) -->
            <Button
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/button_yellow"
                app:backgroundTint="@null"
                android:text="Create Account"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>