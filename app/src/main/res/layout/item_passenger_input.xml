<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bus_yellow"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="16dp">

    <TextView
        android:id="@+id/tvPassengerNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Passenger Details"
        android:textColor="@color/text_dark"
        android:textSize="20sp"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Your name, date of birth, and gender must match the government-issued ID you'll show at the station."
        android:textColor="@color/text_dark"
        android:textSize="12sp"
        android:lineSpacingExtra="2dp"/>


    <!-- required field indicator -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:layout_width="17dp"
            android:layout_height="15dp"
            android:background="@drawable/dot_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Required field"
            android:textColor="@color/text_dark"
            android:textSize="11sp"/>
    </LinearLayout>


    <!-- first name -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="First name"
        android:textColor="@color/text_dark"
        android:textSize="12sp"/>

    <EditText
        android:id="@+id/etFirstName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/input_background"
        android:padding="12dp"
        android:textColor="@color/text_dark"
        android:textSize="14sp"
        android:inputType="textPersonName|textCapWords"/>

    <!-- last name -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Last name"
        android:textColor="@color/text_dark"
        android:textSize="12sp"/>

    <EditText
        android:id="@+id/etLastName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/input_background"
        android:padding="12dp"
        android:textColor="@color/text_dark"
        android:textSize="14sp"
        android:inputType="textPersonName|textCapWords"/>

    <!-- suffix drop down -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Suffix"
        android:textColor="@color/text_dark"
        android:textSize="12sp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:hintEnabled="false">

        <AutoCompleteTextView
            android:id="@+id/autoCompleteSuffix"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:inputType="none"
            android:padding="12dp"
            android:text="None"
            android:textColor="@color/text_dark"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- date of birth -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Date of birth"
        android:textColor="@color/text_dark"
        android:textSize="12sp"/>

    <EditText
        android:id="@+id/etDateOfBirth"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/input_background"
        android:padding="12dp"
        android:textColor="@color/text_dark"
        android:textSize="14sp"
        android:focusable="false"
        android:clickable="true"
        android:hint="MM/DD/YYYY"/>

    <!-- dropdown gender -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Gender"
        android:textColor="@color/text_dark"
        android:textSize="12sp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:hintEnabled="false">

        <AutoCompleteTextView
            android:id="@+id/autoCompleteGender"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_background"
            android:inputType="none"
            android:padding="12dp"
            android:text="Select Gender"
            android:textColor="@color/text_dark"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>