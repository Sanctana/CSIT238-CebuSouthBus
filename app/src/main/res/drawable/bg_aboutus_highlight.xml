<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The light yellow background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/header_yellow_bg" />
        </shape>
    </item>
    <!-- The darker yellow border on the left -->
    <item android:right="350dp"> <!-- Adjust this to control border thickness -->
        <shape android:shape="rectangle">
            <solid android:color="@color/header_yellow_border" />
        </shape>
    </item>
</layer-list>